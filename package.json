{
  "name": "aeronyx-memchain",
  "version": "0.3.0",
  "description": "AeroNyx MemChain 4-layer cognitive memory for OpenClaw agents. Supports local, remote, and cloud modes with Ed25519 authentication, end-to-end encryption, keyword search, and conversation replay.",
  "license": "MIT",
  "author": "AeroNyx Team",
  "homepage": "https://github.com/AeroNyxNetwork/openclaw-memchain",
  "repository": {
    "type": "git",
    "url": "https://github.com/AeroNyxNetwork/openclaw-memchain.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memchain",
    "aeronyx",
    "ai-memory",
    "cognitive-memory",
    "long-term-memory",
    "e2e-encryption"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "skills/",
    "hooks/",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "hooks": [
      "./hooks/memchain-lifecycle"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.0",
    "@noble/hashes": "^1.7.0",
    "@noble/ciphers": "^1.2.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.7"
  },
  "devDependencies": {
    "openclaw": "^2026.3.7",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
